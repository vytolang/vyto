// Regression: gfx_image_load_bytes (in-memory decode, used by Image/Avatar's
// http:// loading path) must decode the same as gfx_image_load_file — no
// curl/network involved, just blend2d's bl_image_read_from_data on bytes
// read straight off disk.
import { loadImageBytes, imageWidth, imageHeight, freeImage } from "volt/gfx";

fn main() {
    let bytes = readfile("apps/iphone/assets/forest.png");
    let h = loadImageBytes(bytes.cstr() as rawptr, bytes.len);
    if (h == null) { print("FAIL null handle"); return; }
    print("w=" + imageWidth(h) + " h=" + imageHeight(h));
    freeImage(h);
}
