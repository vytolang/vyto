// Pure-Vyto coverage for vyto/anim (Clock + Anim + easings) and
// vyto/geom/path (flatten) — no blend2d, so this runs on every host, unlike
// the gfx_* tests gated on libblend2d. Deterministic, golden-checked.
import { Clock, Anim, ease_linear, ease_out_cubic,
         ease_in_out_quad, ease_out_bounce } from "vyto/anim";
import { Path } from "vyto/geom/path";

fn main() {
    // a value tween 0->100 over 1000ms, ease_out_cubic, stepped by hand
    let clk = new Clock();
    let a = clk.add(new Anim(0.0, 100.0, 1000, ease_out_cubic));
    print("t0=" + (a.value() as int));
    clk.advance(250); print("t250=" + (a.value() as int));
    clk.advance(250); print("t500=" + (a.value() as int));
    clk.advance(500); print("t1000=" + (a.value() as int) + " fin=" + a.finished());
    print("active=" + clk.active());

    // easing spot-checks (value at a point, ×1000 truncated)
    print("lin.5=" + ((ease_linear(0.5) * 1000.0) as int));
    print("quadio.5=" + ((ease_in_out_quad(0.5) * 1000.0) as int));
    print("bounce1=" + ((ease_out_bounce(1.0) * 1000.0) as int));

    // looping ping-pong: 0->10 over 100ms
    let lp = new Anim(0.0, 10.0, 100, ease_linear);
    lp.looping();
    lp.advance(25); print("loop25=" + (lp.value() as int));
    lp.advance(100); print("loop125=" + (lp.value() as int));

    // Path.flatten of a straight triangle: move + 2 lines + close = 4 points,
    // and close returns to the start x
    let p = new Path();
    p.moveTo(0.0, 0.0);
    p.lineTo(10.0, 0.0);
    p.lineTo(10.0, 10.0);
    p.close();
    let fp = p.flatten();
    print("flat=" + fp.xs.len + " closeX=" + fp.xs[fp.xs.len - 1]);
}
