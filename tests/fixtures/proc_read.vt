// Regression: readfile/readlines must read growable /proc files (size 0 by
// stat) to EOF, not return empty.
fn main() {
    let lines = readlines("/proc/self/status");
    let hit = 0;
    for (let i in 0..lines.len) {
        if (lines[i].len >= 6 && lines[i].slice(0, 6) == "VmRSS:") { hit = 1; }
    }
    if (hit == 1) { print("ok"); } else { print("EMPTY"); }
}
