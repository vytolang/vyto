// Exercises the stdlib search path:
// - "vyto/hello" resolves via $VYTO_HOME/lib (package layout, name-mangled module)
// - a user module with the same leaf name ("hello") coexists
import { lib_greet } from "vyto/hello";
import { user_greet } from "hello";

fn main() {
    print(lib_greet());
    print(user_greet());
}
