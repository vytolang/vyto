import { Window, Column, TableColumn, Table } from "vyto/ui";
fn first(t: Table): string { if (t.view.len == 0) { return "-"; } return t.rows[t.view[0]][0]; }
fn main() {
    let win = new Window("Tbl", 480, 360);
    let cols = [new TableColumn("Name", 160), new TableColumn("Role", 120), new TableColumn("Age", 60)];
    let t = new Table(cols);
    t.set_rows([
        ["Alice","Engineer","31"],["Bob","Designer","27"],["Carol","PM","44"],
        ["Dave","Engineer","39"],["Eve","Sales","22"],["Frank","Support","35"],
        ["Grace","Engineer","29"],["Heidi","Legal","51"],["Ivan","Sales","41"],["Judy","Design","33"],
    ]);
    print("all=" + t.view.len);
    t.set_query("eng");   print("q=" + t.view.len);
    t.set_query("");
    t.toggle_sort(0);     print("asc=" + first(t));
    t.toggle_sort(0);     print("desc=" + first(t));
    t.sort_col = -1; t.apply();
    print("maxpage=" + t.max_page());
    t.go_page(1);         print("page=" + t.page);
    win.root = new Column([t]);
    win.run();
    print("done");
}
