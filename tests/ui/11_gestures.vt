// Headless coverage for WS9a/9b: drag (mouse-move while press_w holds
// capture) and right-click (EV_MOUSE_RDOWN -> Widget.on_context). A bare
// Widget's default arrange() fills whatever rect the parent (here, Window)
// gives it, so this needs no measure/arrange override to cover the whole
// window and be hit-testable.
import { Window, Widget } from "volt/ui";

class Pad extends Widget {
    fn init() {
        super.init();
        this.focusable = true;
    }
    override fn on_click(x: int, y: int): bool { return true; } // capture press
    override fn on_drag(dx: int, dy: int): bool {
        print("drag " + dx + "," + dy);
        return true;
    }
    override fn on_context(x: int, y: int): bool {
        print("context " + x + "," + y);
        return true;
    }
}

fn main() {
    let win = new Window("Gestures", 200, 150);
    let p = new Pad();
    win.root = p;
    win.run();
}
