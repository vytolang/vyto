import { Window, Center, Painter, stepChart } from "vyto/ui";
import { Rect } from "vyto/surface";
import { Path } from "vyto/geom/path";
class RP extends Painter {
    override fn fill_round(r: Rect, radius: int, color: int) { print("card " + r.x + "," + r.y + " " + r.w + "x" + r.h); }
    override fn stroke_round(r: Rect, radius: int, width: int, color: int) { }
    override fn line(x0: int, y0: int, x1: int, y1: int, color: int) { print("line " + x0 + "," + y0 + " -> " + x1 + "," + y1); }
    override fn stroke_path(p: Path, width: int, color: int) { print("path pts=" + (p.coords.len / 2)); }
    override fn text(x: int, y: int, s: string, color: int) { print("text " + s); }
    override fn text_in(r: Rect, pad: int, s: string, color: int) { }
    override fn text_width(s: string): int { return s.len * 7; }
    override fn font_ascent(): int { return 11; }
    override fn font_height(): int { return 14; }
    override fn width(): int { return 400; }
    override fn height(): int { return 240; }
    override fn present() { print("--present--"); }
}
fn main() {
    let win = new Window("Step", 400, 240);
    win.use_painter(new RP());
    win.root = new Center(stepChart([1.0, 3.0, 2.0, 4.0]).title("S").grid(false).instant());
    win.run();
}
