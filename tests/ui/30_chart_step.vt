import { Window, Center, Painter, stepChart } from "vyto/ui";
import { Rect } from "vyto/surface";
import { Path } from "vyto/geom/path";
class RP extends Painter {
    override fn fill_round(r: Rect, radius: float, color: int) { print("card " + r.x + "," + r.y + " " + r.w + "x" + r.h); }
    override fn stroke_round(r: Rect, radius: float, width: float, color: int) { }
    override fn line(x0: float, y0: float, x1: float, y1: float, color: int) { print("line " + x0 + "," + y0 + " -> " + x1 + "," + y1); }
    override fn stroke_path(p: Path, width: float, color: int) { print("path pts=" + (p.coords.len / 2)); }
    override fn text(x: float, y: float, s: string, color: int) { print("text " + s); }
    override fn text_in(r: Rect, pad: float, s: string, color: int) { }
    override fn text_width(s: string): float { return (s.len * 7) as float; }
    override fn font_ascent(): float { return 11.0; }
    override fn font_height(): float { return 14.0; }
    override fn width(): float { return 400.0; }
    override fn height(): float { return 240.0; }
    override fn present() { print("--present--"); }
}
fn main() {
    let win = new Window("Step", 400, 240);
    win.use_painter(new RP());
    win.root = new Center(stepChart([1.0, 3.0, 2.0, 4.0]).title("S").grid(false).instant());
    win.run();
}
