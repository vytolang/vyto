// Funnel golden: one 4-point trapezoid polygon per stage + stage labels.
import { Window, Center, Painter, funnel } from "vyto/ui";
import { Rect } from "vyto/surface";

class RecordPainter extends Painter {
    override fn fill_round(r: Rect, radius: int, color: int) { }
    override fn stroke_round(r: Rect, radius: int, width: int, color: int) { }
    override fn polygon(xs: i32[], ys: i32[], color: int) { print("stage pts=" + xs.len); }
    override fn text(x: int, y: int, s: string, color: int) { print("text " + s); }
    override fn text_in(r: Rect, pad: int, s: string, color: int) { print("text " + s); }
    override fn text_width(s: string): int { return s.len * 7; }
    override fn font_ascent(): int { return 11; }
    override fn font_height(): int { return 14; }
    override fn width(): int { return 360; }
    override fn height(): int { return 260; }
    override fn present() { print("--present--"); }
}

fn main() {
    let win = new Window("Funnel", 360, 260);
    win.use_painter(new RecordPainter());
    let c = funnel(["Visits", "Signups", "Paid"], [1000.0, 400.0, 120.0]).title("F").instant();
    win.root = new Center(c);
    win.run();
}
