// UTF-8 text editing: multibyte input arrives as one key event with the full
// sequence as text; Backspace/Delete/arrows step whole sequences, never
// splitting a character.
import { Window, Column, TextField } from "vyto/ui";

fn main() {
    let win = new Window("utf8", 300, 100);
    let tf = new TextField("type here");
    tf.onSubmit = (t) => {
        print("submit '" + t + "' bytes " + str(t.len));
    };
    win.root = new Column([tf]);
    win.run();
}
