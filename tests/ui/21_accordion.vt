// Accordion flicker fix: toggling uses the dirty-region path (no full redraw)
// and hover tint tracks a single header. Assert toggle state + per-header hover.
import { Window, Column, Accordion, Label } from "vyto/ui";
fn main() {
    let win = new Window("Acc", 300, 240);
    let acc = new Accordion(["One", "Two", "Three"]);
    acc.add_section(new Label("body one"));
    acc.add_section(new Label("body two"));
    acc.add_section(new Label("body three"));
    win.root = new Column([acc]);
    win.run();
    print("exp=" + acc.expanded[0] + "," + acc.expanded[1] + "," + acc.expanded[2]);
    print("hover_i=" + acc.hover_i);
}
