// Headless coverage for key-release events (EV_KEY_UP) alongside presses.
import { Surface, EV_KEY, EV_KEY_UP, EV_CLOSE } from "vyto/surface";
fn main() {
    let s = new Surface("k", 100, 100);
    for (let i in 0..8) {
        let ev = s.wait_timeout(50);
        if (ev == EV_KEY) { print("down " + s.key()); }
        else if (ev == EV_KEY_UP) { print("up " + s.key()); }
        else if (ev == EV_CLOSE) { print("close"); return; }
    }
}
