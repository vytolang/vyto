// D5: every OS skin ships a paired dark theme. Each must have dark surfaces
// (from the theme_dark base) and its skin's accent re-derived onto them.

import { Theme, theme_light, theme_dark,
         theme_ios, theme_ios_dark,
         theme_material, theme_material_dark,
         theme_macos, theme_macos_dark } from "vyto/ui";

fn check(label: string, cond: bool) {
    let mark = "FAIL";
    if (cond) { mark = "ok"; }
    print(mark + " " + label);
}

fn lum(c: int): int {
    let r = (c >> 16) & 0xFF;
    let g = (c >> 8) & 0xFF;
    let b = c & 0xFF;
    return (r + g + b) / 3;
}

fn main() {
    let light = new Theme();
    let dark = theme_dark();
    check("base light surface is light", lum(light.surface) > 200);
    check("base dark surface is dark", lum(dark.surface) < 60);

    // each skin dark variant sits on dark surfaces
    check("ios dark has a dark surface", lum(theme_ios_dark().surface) < 60);
    check("material dark has a dark surface", lum(theme_material_dark().surface) < 60);
    check("macos dark has a dark surface", lum(theme_macos_dark().surface) < 60);

    // accents survive onto the dark base (not the base blue)
    let id = theme_ios_dark();
    check("ios dark accent is its brighter blue", ((id.primary >> 16) & 0xFF) < 40 && (id.primary & 0xFF) > 200);
    check("ios dark re-derived primary_700", id.primary_700 != dark.primary_700);

    // Material 3 dark flips tonal roles: light lavender primary, dark text on it
    let md = theme_material_dark();
    check("material dark primary is light", lum(md.primary) > 150);
    check("material dark on_primary is dark", lum(md.on_primary) < 90);

    // the light variants are unchanged by the refactor (accent helper parity)
    check("ios light primary intact", theme_ios().primary == light_ios_blue());
    check("light/dark share nothing mutable", theme_ios().surface != theme_ios_dark().surface);
}

fn light_ios_blue(): int { return 0xFF007AFF; }
