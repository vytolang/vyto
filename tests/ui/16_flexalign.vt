// justify-content (main-axis distribution) + align-items / align-self
// (cross-axis alignment) on Row/Column.
import { Window, Widget, Column, Row, SizedBox, Button, Label } from "vyto/ui";
import { JUSTIFY_BETWEEN, JUSTIFY_CENTER, JUSTIFY_END,
         CROSS_CENTER, CROSS_START, CROSS_END } from "vyto/ui/layout";

fn dump(name: string, w: Widget) {
    print(name + "=" + w.bounds.x + "," + w.bounds.y + " " + w.bounds.w + "x" + w.bounds.h);
}

fn main() {
    let win = new Window("Flex", 320, 200);

    // Row 1: space-between across the full (stretched) width — free horizontal
    // space split into equal gaps between the three fixed buttons.
    let a = new Button("A");
    let b = new Button("B");
    let c = new Button("C");
    let r1 = new Row([a, b, c]).justify(JUSTIFY_BETWEEN);

    // Row 2: 60px tall (SizedBox sizer) so cross-axis alignment is visible.
    // align=center centers each button vertically; the middle child overrides
    // itself to the bottom edge with selfAlign.
    let tall = new SizedBox(1, 60, null);
    let d = new Button("D");
    let e = new Button("EE");
    let f = new Button("F");
    e.selfAlign(CROSS_END);
    let r2 = new Row([tall, d, e, f]).align(CROSS_CENTER);

    // Column: justify-end packs the two rows to the bottom; cross default
    // (stretch) keeps each row full-width.
    win.root = new Column([r1, r2]).justify(JUSTIFY_END);
    win.run();

    dump("r1", r1); dump("A", a); dump("B", b); dump("C", c);
    dump("r2", r2); dump("tall", tall); dump("D", d); dump("E", e); dump("F", f);
}
