// Menu: open a menu, arrow + Enter fires the item; Esc dismisses without firing.
import { Window, Column, Label, MenuBar, Menu } from "vyto/ui";

fn main() {
    let win = new Window("Menu", 300, 200);
    let bar = new MenuBar();
    let file = bar.add_menu(new Menu("File"));
    file.add("New").onSelect = () => print("fire:New");
    file.add("Open").onSelect = () => print("fire:Open");
    file.add("Exit").onSelect = () => win.close();
    win.menubar = bar;
    win.close_on_esc = false;
    win.root = new Column([new Label("body")]);
    win.run();
    print("done");
}
