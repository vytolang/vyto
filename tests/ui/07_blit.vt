// Guards the Surface.blit path: i32[] framebuffer -> `as rawptr` -> vs_blit
// binding. Headless blit is a no-op, so this asserts the whole
// cast/binding/wrapper chain compiles and runs (pixels verified on real X11).
import { Surface, Rect } from "volt/surface";

fn main() {
    let s = new Surface("blit", 64, 32);
    let fb: i32[] = [];
    for (let i in 0..64 * 32) {
        fb.push((i % 2) as i32);
    }
    s.blit(fb, 64, 32, Rect(0, 0, 64, 32));
    s.present();
    print("blit ok, fb len=" + fb.len);
}
