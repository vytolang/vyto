// DataTable: header-click sorts natively, keyboard moves the selection and
// keeps it visible via row virtualization, search filters through the engine.
import { Window, Column } from "vyto/ui";
import { DataTable } from "vyto/ui/datatable";
import { DataFrame, CK_I64, CK_STR } from "vyto/data/frame";

fn main() {
    let df = new DataFrame(16);
    let id = df.addColumn("id", CK_I64);
    let name = df.addColumn("name", CK_STR);
    df.reserve(15);
    for (let i in 0..15) {
        df.beginRow().setInt(id, 15 - i).setStr(name, "row" + str(i)).endRow();
    }

    let win = new Window("DT", 500, 300);
    let dt = new DataTable(df);
    dt.onSelect = (v) => print("select " + str(v));
    win.root = new Column([dt.flex(1)]);
    win.run();

    print("sort_col=" + str(dt.sort_col) + " asc=" + str(dt.sort_asc));
    print("row0 id=" + df.cellStr(0, id) + " name=" + df.cellStr(0, name));
    print("selected=" + str(dt.selected) + " viewLen=" + str(df.viewLen()));
}
