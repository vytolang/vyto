import { Window, Center, Painter, gauge } from "vyto/ui";
import { Rect } from "vyto/surface";
class RP extends Painter {
    override fn fill_round(r: Rect, radius: int, color: int) { }
    override fn stroke_round(r: Rect, radius: int, width: int, color: int) { }
    override fn stroke_arc(cx: int, cy: int, rx: int, ry: int, start_deg: int, sweep_deg: int, width: int, color: int) {
        print("arc c=" + cx + "," + cy + " r=" + rx + " start=" + start_deg + " sweep=" + sweep_deg + " w=" + width);
    }
    override fn text(x: int, y: int, s: string, color: int) { print("text " + s); }
    override fn text_width(s: string): int { return s.len * 7; }
    override fn font_ascent(): int { return 11; }
    override fn font_height(): int { return 14; }
    override fn width(): int { return 240; }
    override fn height(): int { return 220; }
    override fn present() { print("--present--"); }
}
fn main() {
    let win = new Window("Gauge", 240, 220);
    win.use_painter(new RP());
    win.root = new Center(gauge(72.0, 100.0).title("CPU").unitLabel("%").instant());
    win.run();
}
