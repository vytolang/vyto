import { Window, Center, Painter, gauge } from "vyto/ui";
import { Rect } from "vyto/surface";
class RP extends Painter {
    override fn fill_round(r: Rect, radius: float, color: int) { }
    override fn stroke_round(r: Rect, radius: float, width: float, color: int) { }
    override fn stroke_arc(cx: float, cy: float, rx: float, ry: float, start_deg: float, sweep_deg: float, width: float, color: int) {
        print("arc c=" + cx + "," + cy + " r=" + rx + " start=" + start_deg + " sweep=" + sweep_deg + " w=" + width);
    }
    override fn text(x: float, y: float, s: string, color: int) { print("text " + s); }
    override fn text_width(s: string): float { return (s.len * 7) as float; }
    override fn font_ascent(): float { return 11.0; }
    override fn font_height(): float { return 14.0; }
    override fn width(): float { return 240.0; }
    override fn height(): float { return 220.0; }
    override fn present() { print("--present--"); }
}
fn main() {
    let win = new Window("Gauge", 240, 220);
    win.use_painter(new RP());
    win.root = new Center(gauge(72.0, 100.0).title("CPU").unitLabel("%").instant());
    win.run();
}
