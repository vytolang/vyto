import { Window, Center, Painter, histogram } from "vyto/ui";
import { Rect } from "vyto/surface";
class RP extends Painter {
    override fn fill_round(r: Rect, radius: int, color: int) { print("bar " + r.x + "," + r.y + " " + r.w + "x" + r.h); }
    override fn stroke_round(r: Rect, radius: int, width: int, color: int) { }
    override fn line(x0: int, y0: int, x1: int, y1: int, color: int) { }
    override fn text(x: int, y: int, s: string, color: int) { print("text " + s); }
    override fn text_width(s: string): int { return s.len * 7; }
    override fn font_ascent(): int { return 11; }
    override fn font_height(): int { return 14; }
    override fn width(): int { return 400; }
    override fn height(): int { return 240; }
    override fn present() { print("--present--"); }
}
fn main() {
    let win = new Window("Hist", 400, 240);
    win.use_painter(new RP());
    win.root = new Center(histogram([1.0,2.0,2.0,3.0,3.0,3.0,4.0,4.0,5.0], 5).title("H").grid(false).instant());
    win.run();
}
