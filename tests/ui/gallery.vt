// VoltGallery headless smoke test — exercises the actual gallery app.
// Verifies it builds, runs, switches tabs, and closes cleanly.
import { Window, Column, Row, Label, Button, TabView, StatusBar, Toolbar, Widget } from "vyto/ui";

class Counter {
    val: int;
    fn init() { this.val = 0; }
    fn bump(): int { this.val += 1; return this.val; }
}

fn main() {
    let win = new Window("GalleryTest", 400, 300);
    let ctr = new Counter();
    let btn = new Button("Bump");
    let lbl = new Label("count: 0");
    btn.onClick = (w) => {
        let c = ctr.bump();
        lbl.text = "count: " + c;
        print("bumped:" + c);
    };
    let tb = new Toolbar(8, 4, [btn, lbl]);
    let tv = new TabView(["A", "B"]);
    tv.grow = 1;
    tv.add_panel(new Label("Tab A content"));
    tv.add_panel(new Label("Tab B content"));
    let sb = new StatusBar("test", "ready");
    win.root = new Column([tb, tv, sb]);
    win.run();
    print("final-count=" + ctr.val);
}
