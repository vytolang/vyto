// Dirty-region repaint: after an in-place widget change, only the affected
// region is repainted, not the whole window. A RecordPainter logs every fill
// so the repainted rectangle is observable. The bg-clear fill at the start of
// each frame reveals the repaint region: full window on the first frame, then
// just the changed widgets' union on later frames.
import { Window, Column, Button, Painter } from "vyto/ui";
import { Rect } from "vyto/surface";

class RecordPainter extends Painter {
    override fn fill(r: Rect, color: int) {
        print("fill " + r.x + "," + r.y + " " + r.w + "x" + r.h);
    }
    // ignore chrome that isn't needed to see the repaint region
    override fn frame(r: Rect, color: int) { }
    override fn text(x: int, y: int, s: string, color: int) { }
    override fn text_in(r: Rect, pad: int, s: string, color: int) { }
    override fn text_width(s: string): int { return s.len * 7; }
    override fn font_ascent(): int { return 11; }
    override fn font_height(): int { return 14; }
    override fn width(): int { return 300; }
    override fn height(): int { return 200; }
    override fn present() { print("--present--"); }
}

fn main() {
    let win = new Window("Dirty", 300, 200);
    win.use_painter(new RecordPainter());
    let a = new Button("a");
    let b = new Button("b");
    b.onClick = (w) => print("fire:" + w.label);
    win.root = new Column([a, b]);
    win.run();
}
