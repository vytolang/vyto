// Headless coverage for the surface game-loop event sources:
// wait_timeout() delivering EV_TIMER ticks interleaved with key events.
import { Surface, EV_TIMER, EV_KEY, EV_CLOSE, KEY_UP, KEY_DOWN } from "volt/surface";

fn main() {
    let s = new Surface("game", 200, 200);
    for (let i in 0..20) {
        let ev = s.wait_timeout(50);
        if (ev == EV_TIMER) {
            print("tick");
        } else if (ev == EV_KEY) {
            let k = s.key();
            if (k == KEY_UP) { print("up"); }
            else if (k == KEY_DOWN) { print("down"); }
            else { print("key " + k); }
        } else if (ev == EV_CLOSE) {
            print("close");
            return;
        } else {
            print("ev " + ev);
        }
    }
}
