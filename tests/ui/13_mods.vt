// Modifier keys + extended key map: Window.mods carries the MOD_* bitmask of
// the event being dispatched; F-keys/PageDown/Space arrive with their codes.
import { Window, Widget } from "vyto/ui";

class KeyProbe extends Widget {
    fn init() {
        super.init();
        this.focusable = true;
    }

    override fn on_key(k: int, ch: string): bool {
        print("key " + str(k) + " mods " + str(this.win.mods) + " ch '" + ch + "'");
        return true;
    }
}

fn main() {
    let win = new Window("mods", 200, 120);
    win.root = new KeyProbe();
    win.run();
    print("done");
}
