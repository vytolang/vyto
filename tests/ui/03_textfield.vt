// TextField editing: insert at caret, arrows, Home/End, Backspace/Delete,
// Enter submits and clears.
import { Window, Column, TextField } from "volt/ui";

fn main() {
    let win = new Window("Text", 300, 100);
    let input = new TextField("placeholder");
    input.onSubmit = (t) => print("submit:" + t);
    win.root = new Column([input]);
    win.run();
    print("text=" + input.text + " caret=" + input.caret);
}
