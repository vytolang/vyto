// Clipboard: Ctrl+C copy, Ctrl+V paste at caret, Ctrl+X cut whole field,
// and paste of an externally-seeded clipboard (the "clip" script directive).
import { Window, Column, TextField } from "vyto/ui";

fn main() {
    let win = new Window("Clip", 300, 100);
    let input = new TextField("ph");
    win.root = new Column([input]);
    win.run();
    print("text=" + input.text + " caret=" + input.caret);
}
