// Headless coverage for WS9c: the Tween/animation clock. An indeterminate
// ProgressBar registers a looping Tween on first draw; each scripted "tick"
// (VS_EV_TIMER) should advance it and move the sweep band's x position —
// proving the clock actually ticks, not just that redraw() re-fires.
import { Window, Column, ProgressBar, Painter } from "vyto/ui";
import { Rect } from "vyto/surface";

class RecordPainter extends Painter {
    override fn fill(r: Rect, color: int) {
        print("fill " + r.x + "," + r.y + " " + r.w + "x" + r.h);
    }
    override fn frame(r: Rect, color: int) { }
    override fn text(x: float, y: float, s: string, color: int) { }
    override fn text_in(r: Rect, pad: float, s: string, color: int) { }
    override fn text_width(s: string): float { return (s.len * 7) as float; }
    override fn font_ascent(): float { return 11.0; }
    override fn font_height(): float { return 14.0; }
    override fn width(): float { return 300.0; }
    override fn height(): float { return 60.0; }
    override fn present() { print("--present--"); }
}

fn main() {
    let win = new Window("Anim", 300, 60);
    win.use_painter(new RecordPainter());
    let pb = new ProgressBar(0.0, -1, -1);
    pb.indeterminate = true;
    win.root = new Column([pb]);
    win.run();
}
