// Toast auto-dismiss lifecycle, AlertBanner close callback, AlertDialog shape,
// and ProgressDialog child wiring (cancel button must be a child so it gets a
// Window ref — else Button.draw null-derefs its skin when show_cancel is on).
import { Window, Column, Button, AlertBanner, SEV_INFO, SEV_ERROR,
         AlertDialog, ProgressDialog, show_toast_msg, SEV_SUCCESS } from "vyto/ui";
fn main() {
    let win = new Window("TA", 380, 220);
    let banner = new AlertBanner(SEV_INFO, "Heads up");
    banner.onClose = () => { print("banner closed"); };
    let b = new Button("toast");
    b.onClick = (bb) => { show_toast_msg(win, "Saved", SEV_SUCCESS); print("toasts_now=" + win.toasts.len); };
    // AlertDialog shape check (buttons built on place via a throwaway layout)
    let ad = new AlertDialog("Confirm", "Proceed?", SEV_ERROR);
    ad.set_actions(["Cancel", "OK"]);
    print("alert_actions=" + ad.actions.len + " sev=" + ad.severity);
    // ProgressDialog must own msg_text + bar + cancel_btn as children (3)
    let pd = new ProgressDialog("Working", "Please wait");
    pd.set_indeterminate(true);
    pd.show_cancel = true;
    print("progress_children=" + pd.children.len);
    win.root = new Column([banner, b]);
    win.run();
    print("toasts_end=" + win.toasts.len);
}
