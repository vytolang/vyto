// FilePicker: list a directory, navigate into a subdir, pick a file.
import { Window, Column, Label, FilePicker } from "volt/ui";

extern "C" {
    fn getenv(name: cstring): cstring;
}

fn main() {
    let dir = str(getenv("VOLT_PICK_DIR".cstr()));
    let win = new Window("Pick", 500, 400);
    let pk = new FilePicker(dir, false);
    pk.onAccept = (p) => print("accept:" + p);
    win.close_on_esc = false;
    win.root = new Column([new Label("body")]);
    win.open_overlay(pk);
    win.run();
    print("done");
}
