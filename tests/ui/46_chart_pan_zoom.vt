// Pan/zoom golden: drag then scroll an interactive time-series and assert the
// x-viewport moved. The RecordPainter draws nothing; the golden is the viewport.
import { Window, Center, Painter, timeSeries, epochISO } from "vyto/ui";
import { Rect } from "vyto/surface";
import { Path } from "vyto/geom/path";

class RecordPainter extends Painter {
    override fn fill_round(r: Rect, radius: int, color: int) { }
    override fn stroke_round(r: Rect, radius: int, width: int, color: int) { }
    override fn line(x0: int, y0: int, x1: int, y1: int, color: int) { }
    override fn stroke_path(p: Path, width: int, color: int) { }
    override fn text(x: int, y: int, s: string, color: int) { }
    override fn text_in(r: Rect, pad: int, s: string, color: int) { }
    override fn text_width(s: string): int { return s.len * 7; }
    override fn font_ascent(): int { return 11; }
    override fn font_height(): int { return 14; }
    override fn width(): int { return 400; }
    override fn height(): int { return 260; }
    override fn present() { }
}

fn pct(v: float): string { return str((v * 100.0) as int); }

fn main() {
    let win = new Window("PZ", 400, 260);
    win.use_painter(new RecordPainter());
    let t0 = epochISO("2026-01-01T00:00:00");
    let times: float[] = [];
    let vals: float[] = [];
    let i = 0;
    while (i < 50) { times.push(t0 + (i as float) * 86400.0); vals.push(10.0 + (i as float)); i += 1; }
    let c = timeSeries(times, vals).interactive();
    win.root = new Center(c);
    print("start " + pct(c.view_lo) + " " + pct(c.view_hi));
    win.run();
    print("end " + pct(c.view_lo) + " " + pct(c.view_hi));
}
