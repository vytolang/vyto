// Two-pass layout: Column/Row/Spacer/grow, re-layout on resize.
import { Window, Widget, Column, Row, Spacer, Label, Button, TextField, ListBox } from "volt/ui";

fn dump(name: string, w: Widget) {
    print(name + "=" + w.bounds.x + "," + w.bounds.y + " " + w.bounds.w + "x" + w.bounds.h);
}

fn main() {
    let win = new Window("Layout", 400, 300);
    let title = new Label("Title");
    let input = new TextField("type here");
    let add = new Button("Add");
    let list = new ListBox();
    input.grow = 1;
    list.grow = 1;
    let row = new Row([input, add]);
    let sp = new Spacer();
    win.root = new Column([title, row, list, sp]);
    win.run();
    dump("title", title);
    dump("row", row);
    dump("input", input);
    dump("add", add);
    dump("list", list);
    dump("spacer", sp);
}
