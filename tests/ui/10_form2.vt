// Phase 4 form interaction: RadioGroup, Switch, Stepper, SegmentedControl.
import { Window, Column, RadioGroup, Switch, Stepper, SegmentedControl, Label, Widget } from "volt/ui";

fn main() {
    let win = new Window("Form2", 300, 400);
    let rg = new RadioGroup(["A", "B", "C"], [1, 2, 3]);
    rg.onChange = (v) => print("radio:" + v);
    let sw = new Switch(false);
    sw.onToggle = (on) => print("switch:" + on);
    let st = new Stepper(0, 0, 10);
    st.onChange = (v) => print("stepper:" + v);
    let sc = new SegmentedControl(["X", "Y", "Z"]);
    sc.onSelect = (i) => print("seg:" + i);
    let info = new Label("done");
    win.root = new Column([rg, sw, st, sc, info]);
    win.run();
    print("final-radio=" + rg.selected);
    print("final-switch=" + sw.on);
    print("final-stepper=" + st.value);
    print("final-seg=" + sc.selected);
}
