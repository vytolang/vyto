// Framebuffer backend, file target: with VS_FBDEV pointed at a regular file
// (sized by VS_FB_W/VS_FB_H, 32bpp XRGB) the surface renders into that file.
// Draws a known pattern the run_tests.sh hexdump check verifies byte-for-byte.
import { Surface, Rect } from "vyto/surface";

fn main() {
    let s = new Surface("fb", 0, 0); // fbdev sizes itself from VS_FB_W/H
    s.fill(Rect(0, 0, s.width(), s.height()), 0x123456);  // background
    s.frame(Rect(0, 0, s.width(), s.height()), 0x00FF00); // green border
    s.fill(Rect(1, 1, 2, 1), 0xFF8800);                   // orange bar, row 1
    s.present();
    print("rendered " + s.width() + "x" + s.height());
}
