// Expanded widget events: hover enter/leave, click-release, key-up, double
// click, long-press, drag start/drag/end, and focus in/out. Two focusable
// boxes print a token per hook; the scripted events exercise each one.
import { Window, Widget, Painter, Theme, Size } from "volt/ui";

class EventBox extends Widget {
    name: string;
    fn init(name: string) {
        super.init();
        this.name = name;
        this.focusable = true;
    }
    override fn measure(s: Painter, th: Theme): Size { return Size(160, 30); }
    override fn draw(s: Painter, th: Theme) { }

    fn log(ev: string): bool { print(this.name + " " + ev); return true; }

    override fn on_click(x: int, y: int): bool { return this.log("click"); }
    override fn on_release(x: int, y: int): bool { return this.log("release"); }
    override fn on_double_click(x: int, y: int): bool { return this.log("double"); }
    override fn on_long_press(x: int, y: int): bool { return this.log("longpress"); }
    override fn on_key_up(k: int): bool { return this.log("keyup"); }
    override fn on_hover_enter(): bool { return this.log("enter"); }
    override fn on_hover_leave(): bool { return this.log("leave"); }
    override fn on_focus(): bool { return this.log("focus"); }
    override fn on_blur(): bool { return this.log("blur"); }
    override fn on_drag_start(x: int, y: int): bool { return this.log("drag_start"); }
    override fn on_drag(dx: int, dy: int): bool { return this.log("drag"); }
    override fn on_drag_end(x: int, y: int): bool { return this.log("drag_end"); }
}

// Column so the two boxes stack at known positions.
import { Column } from "volt/ui";

fn main() {
    let win = new Window("Events", 200, 120);
    let a = new EventBox("A");
    let b = new EventBox("B");
    win.root = new Column([a, b]);
    win.run();
    print("A=" + a.bounds.x + "," + a.bounds.y + " " + a.bounds.w + "x" + a.bounds.h);
    print("B=" + b.bounds.x + "," + b.bounds.y + " " + b.bounds.w + "x" + b.bounds.h);
}
