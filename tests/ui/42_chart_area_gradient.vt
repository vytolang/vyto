// Gradient area fill golden: counts the per-column gradient_v calls the fill
// emits (one 1px column across the curve span).
import { Window, Center, Painter, areaChart } from "vyto/ui";
import { Rect } from "vyto/surface";
import { Path } from "vyto/geom/path";

class RecordPainter extends Painter {
    grads: int;
    fn init() { super.init(); this.grads = 0; }
    override fn fill_round(r: Rect, radius: float, color: int) { print("card " + r.w + "x" + r.h); }
    override fn stroke_round(r: Rect, radius: float, width: float, color: int) { }
    override fn line(x0: float, y0: float, x1: float, y1: float, color: int) { }
    override fn gradient_v(r: Rect, radius: float, top: int, bottom: int) { this.grads += 1; }
    override fn stroke_path(p: Path, width: float, color: int) { print("stroke pts=" + (p.coords.len / 2)); }
    override fn text(x: float, y: float, s: string, color: int) { print("text " + s); }
    override fn text_in(r: Rect, pad: float, s: string, color: int) { print("text " + s); }
    override fn text_width(s: string): float { return (s.len * 7) as float; }
    override fn font_ascent(): float { return 11.0; }
    override fn font_height(): float { return 14.0; }
    override fn width(): float { return 400.0; }
    override fn height(): float { return 260.0; }
    override fn present() { print("gradient_v>0 " + str(this.grads > 0)); print("--present--"); }
}

fn main() {
    let win = new Window("Grad", 400, 260);
    win.use_painter(new RecordPainter());
    let c = areaChart([5.0, 9.0, 7.0, 14.0, 11.0]).gradientFill(true).title("G").instant();
    win.root = new Center(c);
    win.run();
}
