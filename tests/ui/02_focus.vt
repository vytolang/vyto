// Focus ring: Tab cycles in tree order with wraparound; Enter fires the
// focused button; click-to-focus moves the ring.
import { Window, Column, Button } from "volt/ui";

fn main() {
    let win = new Window("Focus", 300, 200);
    let a = new Button("a");
    let b = new Button("b");
    let c = new Button("c");
    a.onClick = (w) => print("fire:" + w.label);
    b.onClick = (w) => print("fire:" + w.label);
    c.onClick = (w) => print("fire:" + w.label);
    win.root = new Column([a, b, c]);
    win.run();
    print("focus-a=" + a.focused + " b=" + b.focused + " c=" + c.focused);
}
