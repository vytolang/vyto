// Text selection + the floating action toolbar. A read-only Text is the root
// (so it fills the window at a known origin). A drag selects a range; the
// toolbar that pops on drag-end is clicked on "Copy", putting the selection on
// the clipboard. Headless surf metrics are a fixed 9px/char, 15px line height,
// so every coordinate below is deterministic.
//
// Window 400x60, single line "hello world foo bar" at origin (0,0):
//   drag x=10 -> col 1, x=100 -> col 11  => selection "ello world"
//   toolbar (Copy, Select All) opens above/below the line; Copy button is the
//   left button — clicked at (30, 28) after the flip-below placement.
import { Window, Text } from "volt/ui";

fn main() {
    let win = new Window("Sel", 400, 60);
    let t = new Text("hello world foo bar");
    win.root = t;
    win.run();
    print("anchor=" + t.sel.anchor + " focus=" + t.sel.focus);
    print("selected=[" + t.text.slice(t.sel.lo(), t.sel.hi()) + "]");
    print("clip=[" + win.surf.clipboard() + "]");
}
