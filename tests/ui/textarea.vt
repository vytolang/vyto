// TextArea: typing, Enter split, Backspace join, arrows, Home/End.
import { Window, Column, TextArea } from "volt/ui";

fn dump(ed: TextArea) {
    print("lines=" + ed.lines.len + " row=" + ed.caret_row + " col=" + ed.caret_col);
    for (let i in 0..ed.lines.len) {
        print("  [" + ed.lines[i] + "]");
    }
}

fn main() {
    let win = new Window("TA", 300, 200);
    let ed = new TextArea();
    ed.grow = 1;
    win.close_on_esc = false;
    win.root = new Column([ed]);
    win.run();
    dump(ed);
    print("text=[" + ed.text() + "]");
}
