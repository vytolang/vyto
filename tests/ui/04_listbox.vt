// ListBox: selection movement keeps the row visible (scroll), space/Enter
// toggles, Delete fires onDelete.
import { Window, Column, ListBox } from "vyto/ui";

fn main() {
    let win = new Window("List", 300, 200);
    let list = new ListBox();
    let items: string[] = ["r0", "r1", "r2", "r3", "r4", "r5", "r6"];
    let checked: bool[] = [false, false, false, false, false, false, false];
    list.set_items(items, checked);
    list.onToggle = (i) => print("toggle:" + i);
    list.onDelete = (i) => print("delete:" + i);
    win.root = new Column([list]);
    win.run();
    print("selected=" + list.selected + " scroll=" + list.scroll);
}
