// Render-snapshot baseline for Button chrome across its visual states.
//
// Unlike the state goldens next to this file, this one asserts on pixels: it
// fingerprints the rendered frame, so a change to shadow, gradient, radius,
// focus ring, or text placement moves the hash. That is the coverage the rest
// of tests/ui does not have.
//
// Note the explicit `focused = false` before the first capture: layout gives
// focus to the first focusable widget, so a Button that has never been touched
// still renders its focus ring. Without clearing it, "default" and "focused"
// would be the same frame and the ring would be untested.
//
// Hover and press are set directly rather than driven through events, so this
// covers Chrome *painting* per state, not the hover-lift animation (which only
// runs via Window.set_hover). Motion is covered separately.
import { Window, Column, Button, Label } from "vyto/ui";
import { Snapshot } from "vyto/gfx/snapshot";

fn main() {
    let win = new Window("Snap", 240, 140);
    let snap = new Snapshot(win, 15.0);

    let b = new Button("Click me");
    win.root = new Column([new Label("Buttons"), b]);
    win.layout();
    b.focused = false;

    snap.capture("default");

    b.hovered = true;
    snap.capture("hovered");
    b.hovered = false;

    b.pressed = true;
    snap.capture("pressed");
    b.pressed = false;

    b.focused = true;
    snap.capture("focused");
    b.focused = false;

    // Returning to the starting state must reproduce the starting frame: if
    // this drifts, some paint is leaking across frames rather than being
    // fully redrawn.
    snap.capture("default-again");
}
