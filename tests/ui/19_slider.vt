// Slider drag: the first real consumer of on_drag / on_drag_start / on_drag_end.
// A press-move-release sequence drives the thumb; onChange reports the value and
// the drag-start/end hooks bracket the motion.
import { Window, Slider } from "vyto/ui";

class LogSlider extends Slider {
    fn init(v: float) { super.init(v); }
    override fn on_drag_start(x: int, y: int): bool {
        print("drag_start");
        this.dragging = true;
        return true;
    }
    override fn on_drag_end(x: int, y: int): bool {
        print("drag_end");
        this.dragging = false;
        return true;
    }
}

fn main() {
    let win = new Window("Slider", 200, 40);
    let sl = new LogSlider(0.0);
    sl.onChange = (v) => { print("change=" + v); };
    win.root = sl;
    win.run();
    print("final=" + sl.value);
}
