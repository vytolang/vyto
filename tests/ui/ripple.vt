// E2: Material button press ripple. A pressed button shows a translucent
// expanding circle clipped to its rounded shape; a resting one shows none.
// Painted over a DARK page so a white ripple spilling past the rounded corner
// would be plainly visible, and a clipped one leaves the corner dark.

import { Window, Theme, Skin, ws, skin_material, theme_material } from "vyto/ui";
import { GfxPainter } from "vyto/gfx/painter";
import { Rect, rgb } from "vyto/surface";

const FONT: string = "/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf";
const BG: int = 0xFF141414;

fn check(label: string, cond: bool) {
    let mark = "FAIL";
    if (cond) { mark = "ok"; }
    print(mark + " " + label);
}

fn lum(px: int): int {
    return (((px >> 16) & 0xFF) + ((px >> 8) & 0xFF) + (px & 0xFF)) / 3;
}

fn paint(p: GfxPainter, sk: Skin, th: Theme, r: Rect, press: float) {
    p.fill(Rect(0.0, 0.0, 140.0, 80.0), BG);
    let st = ws(press > 0.0, press > 0.0, false, false, false);
    st.press = press;
    st.hover = press;
    sk.button.paint(p, th, r, "", st, sk);
    p.canvas.flush();
}

fn main() {
    let win = new Window("R", 140, 80);
    let p = new GfxPainter(win.surface(), FONT, 15.0);
    let sk = skin_material();
    let th = theme_material();
    let r = Rect(20.0, 20.0, 100.0, 40.0);

    paint(p, sk, th, r, 0.0);
    let rest_center = lum(p.canvas.pixelAt(70, 40));
    paint(p, sk, th, r, 0.5);
    let press_center = lum(p.canvas.pixelAt(70, 40));
    check("ripple lightens the button center", press_center > rest_center + 15);

    // At a strong press the unclipped ripple would reach the top-right corner.
    // (118,22) is inside the bounding box but outside the rounded arc; clipped
    // it stays near the dark page, spilled it would jump toward white.
    paint(p, sk, th, r, 0.9);
    let corner = lum(p.canvas.pixelAt(118, 22));
    check("ripple stays inside the rounded shape", corner < 60);
}
