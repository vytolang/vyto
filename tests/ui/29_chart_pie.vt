// Pie/donut chart golden: filled wedges logged as polygons, the donut hole as
// a circle. .instant() sets the radial draw-in to its final frame.
import { Window, Center, Painter, pieChart } from "vyto/ui";
import { Rect } from "vyto/surface";
import { Path } from "vyto/geom/path";

class RecordPainter extends Painter {
    override fn fill_round(r: Rect, radius: float, color: int) { }
    override fn stroke_round(r: Rect, radius: float, width: float, color: int) { }
    override fn polygon(xs: float[], ys: float[], color: int) {
        print("wedge pts=" + xs.len);
    }
    override fn circle(cx: float, cy: float, radius: float, color: int) {
        print("hole " + cx + "," + cy + " r" + radius);
    }
    override fn text(x: float, y: float, s: string, color: int) { print("text " + s); }
    override fn text_in(r: Rect, pad: float, s: string, color: int) { print("text " + s); }
    override fn text_width(s: string): float { return (s.len * 7) as float; }
    override fn font_ascent(): float { return 11.0; }
    override fn font_height(): float { return 14.0; }
    override fn width(): float { return 300.0; }
    override fn height(): float { return 260.0; }
    override fn present() { print("--present--"); }
}

fn main() {
    let win = new Window("Pie", 300, 260);
    win.use_painter(new RecordPainter());
    let c = pieChart(["Rent", "Food", "Fun"], [50.0, 30.0, 20.0])
        .title("P").donut(0.5).instant();
    win.root = new Center(c);
    win.run();
}
