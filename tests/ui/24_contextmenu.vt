// Right-click a host -> ContextMenu opens as an overlay; choosing an item fires.
import { Window, Column, Widget, Painter, Theme, Size, ContextMenu } from "vyto/ui";
class Host extends Widget {
    cm: ContextMenu;
    fn init() {
        super.init();
        this.focusable = true;
        this.cm = new ContextMenu();
        let rn = this.cm.add("Rename");
        rn.onSelect = () => { print("chose Rename"); };
        let del = this.cm.add("Delete");
        del.onSelect = () => { print("chose Delete"); };
    }
    override fn measure(s: Painter, th: Theme): Size { return Size(200, 120); }
    override fn draw(s: Painter, th: Theme) { s.fill(this.bounds, th.surface_raised); }
    override fn on_context(x: int, y: int): bool { this.cm.open(this.win, x as float, y as float); return true; }
}
fn main() {
    let win = new Window("Ctx", 260, 180);
    let h = new Host();
    win.root = new Column([h]);
    win.run();
    print("overlay_after=" + (win.overlay != null));
}
