import { Window, Column, TreeNode, TreeView } from "vyto/ui";
fn main() {
    let win = new Window("Tree", 300, 260);
    let tv = new TreeView();
    let r = new TreeNode("root"); r.expanded = true;
    let a = new TreeNode("a"); a.expanded = true; a.add(new TreeNode("a1")); a.add(new TreeNode("a2"));
    r.add(a); r.add(new TreeNode("b"));
    tv.add_root(r);
    tv.rebuild(); print("vis=" + tv.flat.len);
    a.expanded = false; tv.rebuild(); print("collapsed=" + tv.flat.len);
    win.root = new Column([tv]);
    win.run();
    print("done");
}
