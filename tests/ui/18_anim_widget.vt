// Widget self-animation: this.animate_value(...) called in init auto-registers
// (via pending_anims, flushed on mount) and is advanced by the Window clock —
// no add_animation. Scripted `tick`s step it; the apply closure prints each
// eased value, proving the frame clock drives it.
import { Window, Widget, Painter, Theme, Size, EASE_LINEAR } from "vyto/ui";

class AnimBox extends Widget {
    v: float;

    fn init() {
        super.init();
        this.v = 0.0;
        let b = this;
        // declared before the widget is mounted (win == null here) — stashed in
        // pending_anims and flushed by propagate_win at layout time.
        this.animate_value(0.0, 1.0, 80, false, EASE_LINEAR, (val) => {
            b.v = val;
            print("v=" + val);
        });
    }

    override fn measure(s: Painter, th: Theme): Size { return Size(100, 40); }
    override fn render(s: Painter, th: Theme) { }
}

fn main() {
    let win = new Window("Anim", 120, 60);
    win.root = new AnimBox();
    win.run();
    print("done");
}
