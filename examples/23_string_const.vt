// string constants: a const may be initialized with a string literal. It is
// immutable and inlined as an immortal string at each use site.

const APP: string = "MyApp";
const VERSION: string = "1.0.0";
const GREETING: string = "hello, world";

fn main() {
    print("APP=" + APP);
    print("VERSION=" + VERSION);
    print(GREETING);
    print(APP + " " + VERSION);
}
