// mathx — a native Vyto package. The C sources in native/src/ are compiled
// and linked automatically by vytoc; no build scripts.

extern "C" {
    fn mx_clamp(x: f64, lo: f64, hi: f64): f64;
    fn mx_fib(n: i32): i64;
}

// idiomatic Vyto wrappers around the raw C surface
export fn clamp(x: float, lo: float, hi: float): float {
    return mx_clamp(x, lo, hi);
}

export fn fib(n: int): int {
    return mx_fib(n as i32) as int;
}
