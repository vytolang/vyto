// Native package with bundled C source: vytoc compiles examples/mathx/native/src
// automatically and links it in.
import { clamp, fib } from "mathx";

fn main() {
    print("clamp(5, 0..2) = " + clamp(5.0, 0.0, 2.0));
    print("clamp(1, 0..2) = " + clamp(1.0, 0.0, 2.0));
    print("fib(30) = " + fib(30));
}
