// Modules: import consts, structs, functions, and classes from another unit.
import { PI, Size, area, Counter } from "geometry";

fn main() {
    let s = Size(4.0, 2.5);
    print("area = " + area(s));
    print("pi*2 = " + PI * 2.0);

    let c = new Counter();
    c.bump();
    c.bump();
    print("count = " + c.bump());
}
