// Helper unit for 07_modules.vt
export const PI: float = 3.14159;

export struct Size {
    w: float;
    h: float;
}

export fn area(s: Size): float { return s.w * s.h; }

export class Counter {
    n: int;
    fn init() { this.n = 0; }
    fn bump(): int {
        this.n += 1;
        return this.n;
    }
}
