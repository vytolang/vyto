// volt/util/helper — small standalone helpers with no dependency on any
// volt/ui type (Painter/Theme/Widget/Rect). Keep this file free of such
// dependencies; anything that touches UI types belongs in volt/ui instead.

// "http://" or "https://" prefix check — used by Image/Avatar to route a
// path through load_image_url instead of load_image.
export fn is_http_url(path: string): bool {
    if (path.len >= 8 && path.slice(0, 8) == "https://") { return true; }
    if (path.len >= 7 && path.slice(0, 7) == "http://") { return true; }
    return false;
}
