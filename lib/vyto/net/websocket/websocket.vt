// vyto/net/websocket — an RFC 6455 client, built on vyto/net/socket.
//
//     let ws = ws_connect("ws://echo.websocket.events/");
//     if (ws != null) {
//         ws.sendText("hello");
//         let m = ws.recv();
//         print(m.text());
//         ws.close(1000);
//     }
//
// Blocking (Vyto has no threads): `recv` waits for the next data frame, and
// transparently answers a server ping with a pong before continuing. The
// socket is owned by the WebSocket and closed on teardown. Client frames are
// masked with random keys (RFC 6455 requirement); the only native code is the
// random-byte source — base64 and framing are pure Vyto. `ws://` only for now;
// `wss://` (TLS) is a follow-up. Failure is soft: ws_connect returns null.

import { Socket, socket_connect } from "vyto/net/socket";

extern "C" {
    fn ws_random(out: cstring, n: i32);
}

export const WS_CONT:   int = 0;
export const WS_TEXT:   int = 1;
export const WS_BINARY: int = 2;
export const WS_CLOSE:  int = 8;
export const WS_PING:   int = 9;
export const WS_PONG:   int = 10;

// A received WebSocket message.
export class WsMessage {
    opcode: int;
    data: byte[];
    fn init(op: int, d: byte[]) { this.opcode = op; this.data = d; }
    fn text(): string { return str(this.data as cstring); }
    fn isText(): bool { return this.opcode == WS_TEXT; }
    fn isBinary(): bool { return this.opcode == WS_BINARY; }
    fn isClose(): bool { return this.opcode == WS_CLOSE; }
}

export class WebSocket {
    sock: Socket;
    open: bool;

    fn init(sock: Socket) { this.sock = sock; this.open = true; }

    fn sendText(s: string) { this.sendFrame(WS_TEXT, strBytes(s)); }
    fn sendBinary(b: byte[]) { this.sendFrame(WS_BINARY, b); }
    fn ping() { this.sendFrame(WS_PING, bytes(0)); }

    fn sendFrame(opcode: int, payload: byte[]) {
        if (!this.open) { return; }
        this.sock.send(encodeFrame(opcode, payload));
    }

    // Treat a short read / oversized frame as a dead connection: stop and hand
    // the caller a close message instead of panicking on a truncated frame.
    fn dead(): WsMessage {
        this.open = false;
        return new WsMessage(WS_CLOSE, bytes(0));
    }

    // Block for the next data frame. Server pings are answered with a pong and
    // skipped; a close frame sets open=false and is returned to the caller.
    fn recv(): WsMessage {
        let h2 = readExact(this.sock, 2);
        if (h2.len < 2) { return this.dead(); }
        let b0 = h2[0] as int;
        let b1 = h2[1] as int;
        let opcode = b0 & 0x0F;
        let masked = (b1 & 0x80) != 0;
        let len = b1 & 0x7F;
        if (len == 126) {
            let e = readExact(this.sock, 2);
            if (e.len < 2) { return this.dead(); }
            len = ((e[0] as int) << 8) | (e[1] as int);
        } else if (len == 127) {
            let e = readExact(this.sock, 8);
            if (e.len < 8) { return this.dead(); }
            len = 0;
            let k = 0;
            while (k < 8) { len = (len << 8) | (e[k] as int); k += 1; }
        }
        // cap the declared payload (the wire allows a full 64-bit length —
        // don't let a hostile server drive an arbitrarily large allocation)
        if (len < 0 || len > 67108864) { return this.dead(); } // 64 MiB
        let mask = bytes(4);
        if (masked) {
            mask = readExact(this.sock, 4);
            if (mask.len < 4) { return this.dead(); }
        }
        let payload = bytes(0);
        if (len > 0) {
            payload = readExact(this.sock, len);
            if (payload.len < len) { return this.dead(); }
        }
        if (masked) {
            let i = 0;
            while (i < len) { payload[i] = ((payload[i] as int) ^ (mask[i & 3] as int)) as byte; i += 1; }
        }
        if (opcode == WS_PING) {
            this.sendFrame(WS_PONG, payload);
            return this.recv();
        }
        if (opcode == WS_CLOSE) { this.open = false; }
        return new WsMessage(opcode, payload);
    }

    fn close(code: int) {
        if (this.open) {
            let p = bytes(2);
            p[0] = ((code >> 8) & 0xFF) as byte;
            p[1] = (code & 0xFF) as byte;
            this.sendFrame(WS_CLOSE, p);
            this.open = false;
        }
        this.sock.close();
    }

    deinit { if (this.open) { this.close(1000); } }
}

// Open a WebSocket to a ws:// URL. Null on parse error, connect failure, or a
// non-101 handshake response.
export fn ws_connect(url: string): WebSocket {
    if (!url.starts_with("ws://")) { return null; } // wss:// (TLS) not yet supported
    let rest = url.slice(5, url.len);
    let slash = rest.index_of("/");
    let hostport = rest;
    let path = "/";
    if (slash >= 0) {
        hostport = rest.slice(0, slash);
        path = rest.slice(slash, rest.len);
    }
    let host = hostport;
    let port = 80;
    let colon = hostport.index_of(":");
    if (colon >= 0) {
        host = hostport.slice(0, colon);
        port = hostport.slice(colon + 1, hostport.len).to_int();
    }

    let sock = socket_connect(host, port);
    if (sock == null) { return null; }
    sock.setTimeoutMs(10000);

    let keyBytes = bytes(16);
    ws_random(keyBytes as cstring, 16 as i32);
    let key = base64_encode(keyBytes);

    let req = "GET " + path + " HTTP/1.1\r\n"
            + "Host: " + hostport + "\r\n"
            + "Upgrade: websocket\r\n"
            + "Connection: Upgrade\r\n"
            + "Sec-WebSocket-Key: " + key + "\r\n"
            + "Sec-WebSocket-Version: 13\r\n\r\n";
    sock.sendText(req);

    let resp = readHandshake(sock);
    if (resp.index_of(" 101") < 0) { sock.close(); return null; }
    // RFC 6455 §4.1: the server must echo base64(SHA1(key + magic GUID)).
    // A mismatch means we are not talking to a real WebSocket endpoint
    // (a transparent proxy or a broken server) — refuse the connection.
    let expect = base64_encode(sha1(strBytes(key + "258EAFA5-E914-47DA-95CA-C5AB0DC85B11")));
    if (header_value(resp, "sec-websocket-accept") != expect) { sock.close(); return null; }
    return new WebSocket(sock);
}

// Value of a header line in a raw HTTP header block (name lowercase), or "".
fn header_value(resp: string, name: string): string {
    for (let ln in resp.split("\r\n")) {
        let c = ln.index_of(":");
        if (c > 0 && ln.slice(0, c).trim().to_lower() == name) {
            return ln.slice(c + 1, ln.len).trim();
        }
    }
    return "";
}

// ---- framing helpers -----------------------------------------------------

// Build a masked client frame (FIN set) for `payload`.
fn encodeFrame(opcode: int, payload: byte[]): byte[] {
    let n = payload.len;
    let hdr = 2;
    if (n > 125 && n <= 65535) { hdr = 4; }
    else if (n > 65535) { hdr = 10; }
    let total = hdr + 4 + n;
    let f = bytes(total);
    f[0] = (0x80 | opcode) as byte;
    if (n <= 125) {
        f[1] = (0x80 | n) as byte;
    } else if (n <= 65535) {
        f[1] = (0x80 | 126) as byte;
        f[2] = ((n >> 8) & 0xFF) as byte;
        f[3] = (n & 0xFF) as byte;
    } else {
        f[1] = (0x80 | 127) as byte;
        f[6] = ((n >> 24) & 0xFF) as byte;
        f[7] = ((n >> 16) & 0xFF) as byte;
        f[8] = ((n >> 8) & 0xFF) as byte;
        f[9] = (n & 0xFF) as byte;
    }
    let maskOff = hdr;
    let mask = bytes(4);
    ws_random(mask as cstring, 4 as i32);
    f[maskOff] = mask[0];
    f[maskOff + 1] = mask[1];
    f[maskOff + 2] = mask[2];
    f[maskOff + 3] = mask[3];
    let po = maskOff + 4;
    let i = 0;
    while (i < n) {
        f[po + i] = ((payload[i] as int) ^ (mask[i & 3] as int)) as byte;
        i += 1;
    }
    return f;
}

// Read exactly `n` bytes (empty on EOF/timeout before `n` arrive).
fn readExact(sock: Socket, n: int): byte[] {
    if (n <= 0) { return bytes(0); }
    let out = bytes(n);
    let got = 0;
    while (got < n) {
        let chunk = sock.recv(n - got);
        if (chunk.len == 0) { return bytes(0); }
        let j = 0;
        while (j < chunk.len) { out[got + j] = chunk[j]; j += 1; }
        got += chunk.len;
    }
    return out;
}

// Read the HTTP handshake response up to the blank-line terminator, one byte at
// a time so no frame data is consumed past the header block.
fn readHandshake(sock: Socket): string {
    let acc = "";
    while (acc.len < 8192) {
        let b = sock.recv(1);
        if (b.len == 0) { break; }
        acc = acc + str(b as cstring);
        if (acc.ends_with("\r\n\r\n")) { break; }
    }
    return acc;
}

// ---- small utilities -----------------------------------------------------

fn strBytes(s: string): byte[] {
    let b = bytes(s.len);
    let i = 0;
    while (i < s.len) { b[i] = s[i] as byte; i += 1; }
    return b;
}

// 32-bit rotate-left on values kept masked to 32 bits.
fn rotl32(x: int, n: int): int {
    let v = x & 0xFFFFFFFF;
    return ((v << n) | (v >> (32 - n))) & 0xFFFFFFFF;
}

// SHA-1 (FIPS 180-1), pure Vyto — needed only for the RFC 6455 handshake
// accept check, so no crypto library gets linked. 20-byte digest.
export fn sha1(data: byte[]): byte[] {
    let ml = data.len;
    let total = ml + 1;
    while (total % 64 != 56) { total += 1; }
    total += 8;
    let msg = bytes(total); // zeroed: padding comes for free
    let i = 0;
    while (i < ml) { msg[i] = data[i]; i += 1; }
    msg[ml] = 0x80 as byte;
    let bits = ml * 8;
    let k = 0;
    while (k < 8) { msg[total - 1 - k] = ((bits >> (k * 8)) & 0xFF) as byte; k += 1; }

    let h0 = 0x67452301;
    let h1 = 0xEFCDAB89;
    let h2 = 0x98BADCFE;
    let h3 = 0x10325476;
    let h4 = 0xC3D2E1F0;

    let off = 0;
    while (off < total) {
        let w: int[] = [];
        let t = 0;
        while (t < 16) {
            let p = off + t * 4;
            w.push(((msg[p] as int) << 24) | ((msg[p + 1] as int) << 16) |
                   ((msg[p + 2] as int) << 8) | (msg[p + 3] as int));
            t += 1;
        }
        while (t < 80) {
            w.push(rotl32(w[t - 3] ^ w[t - 8] ^ w[t - 14] ^ w[t - 16], 1));
            t += 1;
        }
        let a = h0; let b = h1; let c = h2; let d = h3; let e = h4;
        let r = 0;
        while (r < 80) {
            let f = 0;
            let kc = 0;
            if (r < 20) { f = (b & c) | ((~b) & d); kc = 0x5A827999; }
            else if (r < 40) { f = b ^ c ^ d; kc = 0x6ED9EBA1; }
            else if (r < 60) { f = (b & c) | (b & d) | (c & d); kc = 0x8F1BBCDC; }
            else { f = b ^ c ^ d; kc = 0xCA62C1D6; }
            let tmp = (rotl32(a, 5) + (f & 0xFFFFFFFF) + e + kc + w[r]) & 0xFFFFFFFF;
            e = d;
            d = c;
            c = rotl32(b, 30);
            b = a;
            a = tmp;
            r += 1;
        }
        h0 = (h0 + a) & 0xFFFFFFFF;
        h1 = (h1 + b) & 0xFFFFFFFF;
        h2 = (h2 + c) & 0xFFFFFFFF;
        h3 = (h3 + d) & 0xFFFFFFFF;
        h4 = (h4 + e) & 0xFFFFFFFF;
        off += 64;
    }

    let hs = [h0, h1, h2, h3, h4];
    let dg = bytes(20);
    let j = 0;
    while (j < 5) {
        dg[j * 4] = ((hs[j] >> 24) & 0xFF) as byte;
        dg[j * 4 + 1] = ((hs[j] >> 16) & 0xFF) as byte;
        dg[j * 4 + 2] = ((hs[j] >> 8) & 0xFF) as byte;
        dg[j * 4 + 3] = (hs[j] & 0xFF) as byte;
        j += 1;
    }
    return dg;
}

export fn base64_encode(data: byte[]): string {
    let tbl = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
    let out = "";
    let i = 0;
    let n = data.len;
    while (i < n) {
        let b0 = data[i] as int;
        let has1 = (i + 1) < n;
        let has2 = (i + 2) < n;
        let b1 = 0;
        let b2 = 0;
        if (has1) { b1 = data[i + 1] as int; }
        if (has2) { b2 = data[i + 2] as int; }
        let triple = (b0 << 16) | (b1 << 8) | b2;
        let c0 = (triple >> 18) & 0x3F;
        let c1 = (triple >> 12) & 0x3F;
        let c2 = (triple >> 6) & 0x3F;
        let c3 = triple & 0x3F;
        out = out + tbl.slice(c0, c0 + 1) + tbl.slice(c1, c1 + 1);
        if (has1) { out = out + tbl.slice(c2, c2 + 1); } else { out = out + "="; }
        if (has2) { out = out + tbl.slice(c3, c3 + 1); } else { out = out + "="; }
        i += 3;
    }
    return out;
}
