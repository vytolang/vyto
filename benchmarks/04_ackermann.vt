// Benchmark 4: Ackermann function (deep recursion)
fn ack(m: int, n: int): int {
    if (m == 0) { return n + 1; }
    if (n == 0) { return ack(m - 1, 1); }
    return ack(m - 1, ack(m, n - 1));
}

fn main() {
    let m = 3;
    let n = 10;
    let result = ack(m, n);
    print("ack(" + m + ", " + n + ") = " + result);
}
